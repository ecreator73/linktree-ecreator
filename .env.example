# ── AI Analyse lead capture (all optional) ───────────────────────────
# If set, leads are written directly to Supabase from the browser
# (requires the RLS insert policy from supabase/schema.sql).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alternatively, POST leads to your own webhook / serverless endpoint
# (e.g. the activation/analysis-lead.route.ts handler on Vercel).
NEXT_PUBLIC_LEAD_ENDPOINT=

# Without any of the above, the form falls back to a prefilled e-mail
# to info@ecreator.ch so no lead is ever lost.

# ── GitHub Pages build only ──────────────────────────────────────────
# Set automatically in CI; leave empty for Vercel / custom domain (root).
# NEXT_PUBLIC_BASE_PATH=/linktree-ecreator
